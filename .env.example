SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Leave unset to use local SQLite. Set to switch to Postgres (dev/staging/production):
# DATABASE_URL=postgres://user:password@localhost:5432/fplaces

# Leave unset to use an in-memory channel layer (single process, fine for local dev).
# Set to fan real-time events out across multiple processes/workers:
# REDIS_URL=redis://localhost:6379/0

FRONTEND_URL=http://localhost:3000

# Leave unset to log emails instead of sending (local dev). Set to send via Resend:
RESEND_API_KEY=re_xxx
DEFAULT_FROM_EMAIL=no-reply@fplaces.app

# Set to redirect all outbound emails to a single inbox (useful for testing/development):
SEND_TO_EMAIL=

